{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "/api-page/404.html"
    },
    {
      "src": "/(.*)",
      "status": 500,
      "dest": "/api-page/500.html"
    },
    {
      "src": "/",
      "dest": "/api-page/index.html"
    },
    {
      "src": "/api-page/(.*)",
      "dest": "/api-page/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
