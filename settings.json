  "categories": [
    {
      "name": "Stalker",
      "icon": "🔍",
      "description": "Social media & game profile lookup",
      "items": [
        {
          "name": "Instagram Stalker",
          "desc": "Get Instagram profile info (username, followers, bio, posts, etc)",
          "path": "/stalk/ig",
          "status": "ready",
          "params": {
            "username": "Instagram username (without @)"
          }
        },
        {
          "name": "Free Fire Stalker",
          "desc": "Get Free Fire player info (nickname, server, last scan time)",
          "path": "/stalk/ff",
          "status": "ready",
          "params": {
            "playerid": "Free Fire Player ID (example: 1234567890)"
          }
        },
        {
          "name": "Roblox Stalker",
          "desc": "Get Roblox player detailed info (username, status, friends, badges, groups, presence)",
          "path": "/stalk/roblox",
          "status": "ready",
          "params": {
            "username": "Roblox username (example: BuilderMan)"
          }
        },
        {
          "name": "NGL Checker",
          "desc": "Check NGL username validity with profile picture",
          "path": "/stalk/ngl",
          "status": "ready",
          "params": {
            "username": "NGL username to verify"
          }
        }
      ]
    },
    {
      "name": "System",
      "icon": "⚙️",
      "description": "API system information & monitoring",
      "items": [
        {
          "name": "API Status",
          "desc": "Check API health, total requests, total features, and uptime",
          "path": "/api/status",
          "status": "ready"
        }
      ]
    }
  ]
